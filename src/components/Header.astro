---
import { useTranslations, getLocalePath } from '../i18n/utils';
import { languages, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { path: '/', label: t('nav.home') },
  { path: '/about', label: t('nav.about') },
  { path: '/blog', label: t('nav.blog') },
  { path: '/contact', label: t('nav.contact') },
];

// Strip locale prefix to get the canonical path for active detection + lang switcher
const rawPath = Astro.url.pathname.replace(/^\/(nl|fr|de)/, '') || '/';
const currentPath = rawPath === '' ? '/' : rawPath;
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-[var(--color-bg)]/90 border-b border-[var(--color-border)]">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between" aria-label={t('nav.aria')}>
    <!-- Logo -->
    <a href={getLocalePath(lang, '/')} class="flex items-center gap-2 group" aria-label="Novatum home">
      <div class="w-8 h-8 rounded-lg bg-[var(--color-primary)] flex items-center justify-center transition-transform duration-200 group-hover:scale-105">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
      </div>
      <span class="font-semibold text-lg text-[var(--color-text)]" style="font-family: var(--font-heading)">Novatum</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1" role="list">
      {navLinks.map(({ path, label }) => (
        <li>
          <a
            href={getLocalePath(lang, path)}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 cursor-pointer ${
              currentPath === path
                ? 'bg-[var(--color-surface-2)] text-[var(--color-primary)]'
                : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]'
            }`}
            aria-current={currentPath === path ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-3">
      <!-- Language switcher -->
      <div class="flex items-center gap-1 text-xs font-medium text-[var(--color-text-muted)]">
        {Object.entries(languages).map(([code, label]) => (
          <a
            href={getLocalePath(code as Lang, currentPath)}
            class={`px-2 py-1 rounded-md transition-colors duration-200 cursor-pointer uppercase tracking-wide ${
              code === lang
                ? 'bg-[var(--color-surface-2)] text-[var(--color-primary)]'
                : 'hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]'
            }`}
            aria-label={label}
            aria-current={code === lang ? 'true' : undefined}
          >
            {code}
          </a>
        ))}
      </div>

      <!-- CTA -->
      <a
        href={getLocalePath(lang, '/contact')}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-[var(--color-cta)] text-[var(--color-cta-text)] text-sm font-semibold hover:bg-[var(--color-cta-dark)] transition-colors duration-200 cursor-pointer"
      >
        {t('nav.cta')}
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 rounded-lg text-[var(--color-text-muted)] hover:bg-[var(--color-surface)] transition-colors duration-200 cursor-pointer"
      aria-label={t('nav.toggle')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-bg)]">
    <ul class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1" role="list">
      {navLinks.map(({ path, label }) => (
        <li>
          <a
            href={getLocalePath(lang, path)}
            class={`block px-4 py-3 rounded-xl text-sm font-medium transition-colors duration-200 cursor-pointer ${
              currentPath === path
                ? 'bg-[var(--color-surface-2)] text-[var(--color-primary)]'
                : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]'
            }`}
            aria-current={currentPath === path ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href={getLocalePath(lang, '/contact')}
          class="block px-4 py-3 rounded-xl bg-[var(--color-cta)] text-[var(--color-cta-text)] text-sm font-semibold text-center hover:bg-[var(--color-cta-dark)] transition-colors duration-200 cursor-pointer"
        >
          {t('nav.cta')}
        </a>
      </li>
      <!-- Mobile language switcher -->
      <li class="pt-2 border-t border-[var(--color-border)] mt-2">
        <div class="flex gap-2 px-4 py-2">
          {Object.entries(languages).map(([code, label]) => (
            <a
              href={getLocalePath(code as Lang, currentPath)}
              class={`px-3 py-1.5 rounded-lg text-xs font-medium uppercase tracking-wide transition-colors duration-200 cursor-pointer ${
                code === lang
                  ? 'bg-[var(--color-surface-2)] text-[var(--color-primary)]'
                  : 'text-[var(--color-text-muted)] hover:bg-[var(--color-surface)]'
              }`}
              aria-label={label}
            >
              {code}
            </a>
          ))}
        </div>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
