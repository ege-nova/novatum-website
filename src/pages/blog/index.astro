---
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base title="Blog" description="Writing on green IT, permacomputing, community tech, and building software for a solarpunk future.">

  <div class="max-w-6xl mx-auto px-6 py-16 md:py-24">

    <div class="max-w-2xl mb-14">
      <h1 class="text-4xl md:text-5xl font-bold mb-4" style="font-family: var(--font-heading)">
        Writing
      </h1>
      <p class="text-xl text-[var(--color-text-muted)] leading-relaxed">
        Thoughts on green IT, permacomputing, community-owned software, and building tech that serves the people who use it.
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-[var(--color-text-muted)]">
        <p class="text-lg">No posts yet — check back soon.</p>
      </div>
    )}

  </div>
</Base>
