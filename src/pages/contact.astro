---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Start a conversation about your project — no pitch decks required.">

  <div class="max-w-3xl mx-auto px-6 py-16 md:py-24">

    <!-- Header -->
    <div class="max-w-xl mb-12">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-surface-2)] text-[var(--color-primary-dark)] text-sm font-medium mb-6">
        Get in touch
      </span>
      <h1 class="text-4xl md:text-5xl font-bold mb-4" style="font-family: var(--font-heading)">
        Let's build something good
      </h1>
      <p class="text-xl text-[var(--color-text-muted)] leading-relaxed">
        Tell us about your project. If it puts people and planet first, we'd love to be part of it.
      </p>
    </div>

    <!-- Contact form -->
    <form
      name="contact"
      method="POST"
      action="/contact/success"
      class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-8 mb-12"
      novalidate
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
        <div>
          <label for="name" class="block text-sm font-medium text-[var(--color-text)] mb-2">
            Your name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            placeholder="Ada Lovelace"
            class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder:text-[var(--color-border)] focus:outline-none focus:border-[var(--color-primary)] transition-colors duration-200 text-sm"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-[var(--color-text)] mb-2">
            Email address
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="ada@example.com"
            class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder:text-[var(--color-border)] focus:outline-none focus:border-[var(--color-primary)] transition-colors duration-200 text-sm"
          />
        </div>
      </div>

      <div class="mb-6">
        <label for="project-type" class="block text-sm font-medium text-[var(--color-text)] mb-2">
          What best describes your project?
        </label>
        <select
          id="project-type"
          name="project-type"
          class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:border-[var(--color-primary)] transition-colors duration-200 text-sm cursor-pointer"
        >
          <option value="">Select one...</option>
          <option value="community">Community initiative or cooperative</option>
          <option value="small-biz">Small business</option>
          <option value="nonprofit">Non-profit or NGO</option>
          <option value="open-source">Open source project</option>
          <option value="other">Something else</option>
        </select>
      </div>

      <div class="mb-8">
        <label for="message" class="block text-sm font-medium text-[var(--color-text)] mb-2">
          Tell us about your project
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          placeholder="What are you building? What problem does it solve? What stage are you at?"
          class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder:text-[var(--color-border)] focus:outline-none focus:border-[var(--color-primary)] transition-colors duration-200 text-sm resize-y min-h-[140px]"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-[var(--color-cta)] text-[var(--color-cta-text)] font-semibold hover:bg-[var(--color-cta-dark)] transition-colors duration-200 cursor-pointer"
      >
        Send message
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </form>

    <!-- Alternatives -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex items-start gap-4 p-5 bg-[var(--color-surface)] rounded-2xl border border-[var(--color-border)]">
        <div class="w-9 h-9 rounded-lg bg-[var(--color-surface-2)] flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-primary)]">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-[var(--color-text)] mb-1" style="font-family: var(--font-heading)">Email</p>
          <p class="text-sm text-[var(--color-text-muted)]">egeuens@novatum.solutions</p>
        </div>
      </div>
      <div class="flex items-start gap-4 p-5 bg-[var(--color-surface)] rounded-2xl border border-[var(--color-border)]">
        <div class="w-9 h-9 rounded-lg bg-[var(--color-surface-2)] flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-primary)]">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-[var(--color-text)] mb-1" style="font-family: var(--font-heading)">GitHub</p>
          <a
            href="https://github.com/ege-nova"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors duration-200"
          >
            github.com/ege-nova
          </a>
        </div>
      </div>
    </div>

  </div>
</Base>
